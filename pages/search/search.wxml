<view class="container">
  <view class="search-bar">
    <input class="search-input" placeholder="请输入搜索内容" bindinput="onSearchInput" value="{{searchInputValue}}" />
    <button class="search-button" bindtap="onSearch">搜索</button>
  </view>
  <view class="title" wx:if="{{showTitleAndKeywords}}">热门商品</view>
  <view class="hot-keywords" wx:if="{{showTitleAndKeywords}}">
    <block wx:for="{{keywords}}" wx:key="index">
      <view class="keyword-item" bindtap="onKeywordClick" data-keyword="{{item}}">{{item}}</view>
    </block>
  </view>
  <view class="search-results">
    <block wx:for="{{searchResults}}" wx:key="id">
      <view class="result-item" bindtap="navigateToDetail" data-id="{{item.id}}">
        <image src="{{item.image}}" mode="aspectFill" />
        <view class="item-info">
          <view class="item-title">{{item.title}}</view>
          <view class="item-price">￥{{item.price}}</view>
        </view>
      </view>
    </block>
  </view>
</view>